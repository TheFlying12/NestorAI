# Copy to .env.test and fill in values to run the test suite locally.
# .env.test is git-ignored — never commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Leave as SQLite for fast local tests (default when this file is absent).
# Point at a real Postgres instance to run integration tests against Postgres.
DATABASE_URL=sqlite+aiosqlite:///./test_nestor.db
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nestor_test

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWKS URL from your Clerk development instance dashboard.
# Used only if you write tests that hit auth-protected endpoints.
CLERK_JWKS_URL=https://<your-clerk-dev-instance>.clerk.accounts.dev/.well-known/jwks.json

# ── Encryption ───────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to skip BYOK key tests.
FERNET_KEY=

# ── LLM ──────────────────────────────────────────────────────────────────────
# Leave blank; integration tests mock LLM calls and do not hit OpenAI.
OPENAI_API_KEY=

# ── App behaviour ────────────────────────────────────────────────────────────
AUTO_MIGRATE=false
ALLOWED_ORIGINS=*
LOG_LEVEL=WARNING
