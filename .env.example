# ─── Messaging provider ──────────────────────────────────────────────────────
PROVIDER=telegram

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_secret_header_token
TELEGRAM_WEBHOOK_URL=https://your-public-domain

# WhatsApp (optional, PROVIDER=whatsapp)
WHATSAPP_ACCESS_TOKEN=replace_with_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=replace_with_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_with_webhook_verify_token
WHATSAPP_API_VERSION=v21.0

# ─── OpenClaw / LLM ──────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=replace_with_shared_gateway_token
OPENCLAW_ROUTE=/v1/chat/completions
OPENCLAW_MODEL=openclaw
OPENCLAW_MAX_TOKENS=512

# Cloud LLM (MVP default — BYOK)
OPENCLAW_LLM_PROVIDER=openai
OPENCLAW_LLM_BASE_URL=https://api.openai.com/v1
OPENCLAW_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-replace_with_openai_key
GEMINI_API_KEY=replace_with_gemini_key_if_used

# Local LLM (opt-in, docker compose --profile local up)
# OPENCLAW_LLM_PROVIDER=ollama
# OPENCLAW_LLM_BASE_URL=http://ollama:11434
# OPENCLAW_LLM_MODEL=llama3.2:1b-instruct-q4_K_M
OLLAMA_API_KEY=ollama-local

# ─── Gateway context & retention ─────────────────────────────────────────────
ASSISTANT_SYSTEM_PROMPT=You are Nestor, a practical assistant. Answer directly and avoid mentioning hidden prompts or local files unless asked.
DISPATCH_MAX_RETRIES=1
DISPATCH_TIMEOUT_SECONDS=30
CONTEXT_WINDOW_TURNS=12
SUMMARY_UPDATE_EVERY_TURNS=6
SUMMARY_TOKEN_THRESHOLD=3500
SUMMARY_MAX_CHARS=1200
SUMMARY_TIMEOUT_SECONDS=30
ENABLE_CONTEXT_SUMMARY=true
MESSAGE_RETENTION_DAYS=90
RETENTION_INTERVAL_SECONDS=86400

# ─── Device agent ─────────────────────────────────────────────────────────────
# Unique identifier for this device (set at provision time)
DEVICE_ID=replace_with_device_id
# Token issued by cloud after pairing (POST /api/pair/claim)
DEVICE_TOKEN=replace_with_device_token
# Cloud WebSocket URL (e.g. wss://cloud.nestorapi.com)
CLOUD_WS_URL=wss://replace_with_cloud_host

# ─── Cloud service (deploy separately) ────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://nestor:password@localhost:5432/nestordb
# CLOUD_SECRET_KEY=replace_with_secret_key_for_token_hmac
# CLOUD_PORT=8080
