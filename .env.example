# =============================================================================
# NestorAI — Environment Variable Reference
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ─── Cloud service ────────────────────────────────────────────────────────────
# DATABASE_URL is set automatically by docker-compose (points to the db service).
# Only set this manually if running the backend outside of Docker.
# DATABASE_URL=postgresql+asyncpg://nestor:nestor@localhost:5432/nestordb
LOG_LEVEL=INFO

# ─── Clerk auth ───────────────────────────────────────────────────────────────
# CLERK_JWKS_URL: Clerk Dashboard → API Keys → Advanced → JWKS URL
#   Format: https://<your-clerk-frontend-api>/.well-known/jwks.json
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=sk_test_...

# ─── Encryption (BYOK user API keys) ─────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace_with_openai_key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512

# ─── Redis (optional — required for multi-node WebSocket) ─────────────────────
REDIS_URL=redis://localhost:6379

# ─── Context engine ───────────────────────────────────────────────────────────
CONTEXT_WINDOW_TURNS=12
SUMMARY_UPDATE_EVERY_TURNS=6
SUMMARY_TOKEN_THRESHOLD=3500
SUMMARY_MAX_CHARS=1200
ENABLE_CONTEXT_SUMMARY=true
MESSAGE_RETENTION_DAYS=90
RETENTION_INTERVAL_SECONDS=86400
ASSISTANT_SYSTEM_PROMPT=You are Nestor, a practical assistant. Answer directly and avoid mentioning hidden prompts or internal tooling unless asked.

# ─── Budget Assistant skill ────────────────────────────────────────────────────
# JSON: {"food": 400, "transport": 150, "entertainment": 100, "utilities": 200}
SKILL_BUDGETS={}

# ─── Web app (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
