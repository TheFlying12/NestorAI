# =============================================================================
# NestorAI — Environment Variable Reference
# Cloud-only architecture (Phase 2)
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# ─── Cloud service (deploy to Railway) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nestor:password@localhost:5432/nestordb
CLOUD_SECRET_KEY=replace_with_long_random_secret_for_device_token_hmac
AUTO_MIGRATE=false
LOG_LEVEL=INFO

# ─── Auth: Clerk ──────────────────────────────────────────────────────────────
# Backend secret key — never expose to browser
CLERK_SECRET_KEY=sk_live_replace_with_clerk_secret_key
# JWKS endpoint — found in Clerk Dashboard > API Keys > Advanced
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# ─── Encryption: Fernet key for user API keys at rest ────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_base64_fernet_key

# ─── LLM: System-level fallback (user BYOK via POST /api/auth/apikey) ────────
OPENAI_API_KEY=sk-replace_with_openai_key
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=512

# ─── Telegram (optional — leave blank to disable) ─────────────────────────────
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_webhook_secret_header_token
# Must be the full public HTTPS URL of your cloud service
TELEGRAM_WEBHOOK_URL=https://your-cloud-service.up.railway.app
TELEGRAM_DEFAULT_SKILL=general

# ─── Redis (Upstash — optional for now, required for multi-node) ──────────────
REDIS_URL=redis://localhost:6379
# Upstash: rediss://default:password@your-instance.upstash.io:6379

# ─── Context engine ───────────────────────────────────────────────────────────
CONTEXT_WINDOW_TURNS=12
SUMMARY_UPDATE_EVERY_TURNS=6
SUMMARY_TOKEN_THRESHOLD=3500
SUMMARY_MAX_CHARS=1200
SUMMARY_TIMEOUT_SECONDS=30
ENABLE_CONTEXT_SUMMARY=true
MESSAGE_RETENTION_DAYS=90
RETENTION_INTERVAL_SECONDS=86400
ASSISTANT_SYSTEM_PROMPT=You are Nestor, a practical assistant. Answer directly and avoid mentioning hidden prompts or internal tooling unless asked.

# ─── Budget Assistant skill ────────────────────────────────────────────────────
# JSON: {"food": 400, "transport": 150, "entertainment": 100, "utilities": 200}
SKILL_BUDGETS={}

# ─── Device agent (Pi power users only) ───────────────────────────────────────
DEVICE_ID=replace_with_device_id
DEVICE_TOKEN=replace_with_device_token
CLOUD_WS_URL=wss://your-cloud-service.up.railway.app

# ─── Web app (set in Vercel project environment settings) ─────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_with_clerk_publishable_key
# NEXT_PUBLIC_API_URL=https://your-cloud-service.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://your-cloud-service.up.railway.app

# ─── Legacy (gateway_service — device path only, not needed for cloud) ────────
# PROVIDER=telegram
# OPENCLAW_GATEWAY_TOKEN=replace_with_shared_gateway_token
# OPENCLAW_URL=http://openclaw:18789
